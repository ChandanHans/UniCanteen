generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  STUDENT
  CANTEEN_ADMIN
  SUPER_ADMIN
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PICKED_UP
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─── MODELS ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         Role     @default(STUDENT)
  hostelId     String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hostel         Hostel?        @relation(fields: [hostelId], references: [id])
  cartItems      CartItem[]
  orders         Order[]
  reviews        Review[]
  notifications  Notification[]
  managedCanteen Canteen?       @relation("CanteenAdmin")
}

model Hostel {
  id        String   @id @default(uuid())
  name      String   @unique
  location  String?
  createdAt DateTime @default(now())

  canteen Canteen?
  users   User[]
}

model Canteen {
  id          String   @id @default(uuid())
  name        String
  hostelId    String   @unique
  adminId     String?  @unique
  description String?
  imageUrl    String?
  lunchStart  String   @default("12:00")
  lunchEnd    String   @default("14:30")
  dinnerStart String   @default("19:00")
  dinnerEnd   String   @default("21:30")
  upiId       String?
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hostel     Hostel         @relation(fields: [hostelId], references: [id])
  admin      User?          @relation("CanteenAdmin", fields: [adminId], references: [id])
  categories MenuCategory[]
  orders     Order[]
}

model MenuCategory {
  id        String   @id @default(uuid())
  name      String
  canteenId String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  canteen Canteen    @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  items   MenuItem[]

  @@unique([canteenId, name])
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(8, 2)
  imageUrl    String?
  categoryId  String
  isVeg       Boolean  @default(true)
  isAvailable Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@index([categoryId, isAvailable])
}

model CartItem {
  id         String   @id @default(uuid())
  userId     String
  menuItemId String
  quantity   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([userId, menuItemId])
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique
  userId              String
  canteenId           String
  status              OrderStatus @default(PLACED)
  totalAmount         Decimal     @db.Decimal(10, 2)
  specialInstructions String?
  meal                String    @default("LUNCH")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  canteen Canteen     @relation(fields: [canteenId], references: [id])
  items   OrderItem[]
  payment Payment?

  @@index([userId, createdAt(sort: Desc)])
  @@index([canteenId, status])
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int
  unitPrice  Decimal @db.Decimal(8, 2)
  itemName   String

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Payment {
  id           String        @id @default(uuid())
  orderId      String        @unique
  amount       Decimal       @db.Decimal(10, 2)
  rzpOrderId   String?       @unique
  rzpPaymentId String?       @unique
  status       PaymentStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  menuItemId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([userId, menuItemId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
}
